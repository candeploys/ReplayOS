# ReplayOS environment variables
REPLAYOS_API_KEYS=replace-with-a-long-random-token
REPLAYOS_ENV=production

# Provider credentials
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional plugin directories (comma-separated)
REPLAYOS_PLUGIN_DIRS=plugins

# Gmail IMAP connector
GMAIL_IMAP_USER=
GMAIL_IMAP_APP_PASSWORD=
GMAIL_IMAP_MAILBOX=INBOX

# Slack connector
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Notion connector
NOTION_API_KEY=

# Example plugin switch
EXAMPLE_CONNECTOR_ENABLED=false
